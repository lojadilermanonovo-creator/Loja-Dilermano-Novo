rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} { allow read, write: if false; }

    // Helpers
    function isSignedIn() { return request.auth != null; }
    function isAdmin() {
      return isSignedIn() &&
             (request.auth.token.admin == true ||
              request.auth.token.email == 'lojadilermanonovo@gmail.com');
    }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation functions
    function isValidProduct(p) {
      return p.name is string && p.name.size() > 0 && p.name.size() <= 200 &&
             p.price is number && p.price >= 0 &&
             p.categoryId is string;
    }

    match /products/{id} {
      allow read;
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /categories/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /banners/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /promoBanner/{id} {
      allow read;
      allow write: if isAdmin();
    }

    match /coupons/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      allow update: if isSignedIn() 
                    && request.resource.data.get('usedCount', 0) == resource.data.get('usedCount', 0) + 1
                    && request.resource.data.get('code', '') == resource.data.get('code', '')
                    && request.resource.data.get('isActive', true) == resource.data.get('isActive', true)
                    && request.resource.data.get('value', 0) == resource.data.get('value', 0)
                    && request.resource.data.get('type', '') == resource.data.get('type', '')
                    && request.resource.data.get('minOrderValue', 0) == resource.data.get('minOrderValue', 0)
                    && request.resource.data.get('maxUses', 0) == resource.data.get('maxUses', 0);
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) || isAdmin();

      match /addresses/{aid} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    match /orders/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /reviews/{id} {
      allow read: if resource.data.isApproved == true || isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /wishlists/{uid} {
      allow read, write: if isOwner(uid);
      match /items/{pid} {
        allow read, write: if isOwner(uid);
      }
    }

    match /settings/{id} {
      allow read: if id == 'general' || id == 'promocta' || id == 'footer' || id == 'popup' || id == 'stripe_public' || isAdmin();
      allow write: if isAdmin();
    }
  }
}
