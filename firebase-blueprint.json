{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "fullName": { "type": "string" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Address": {
      "title": "Address",
      "description": "User address",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "street": { "type": "string" },
        "number": { "type": "string" },
        "complement": { "type": "string" },
        "neighborhood": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zipCode": { "type": "string" },
        "isDefault": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "parentId": { "type": "string" },
        "sortOrder": { "type": "number" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "shortDescription": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "costPrice": { "type": "number" },
        "sku": { "type": "string" },
        "barcode": { "type": "string" },
        "weightGrams": { "type": "number" },
        "widthCm": { "type": "number" },
        "heightCm": { "type": "number" },
        "lengthCm": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "lowStockThreshold": { "type": "number" },
        "categoryId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "isActive": { "type": "boolean" },
        "isFeatured": { "type": "boolean" },
        "isNew": { "type": "boolean" },
        "images": { "type": "array", "items": { "type": "object" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "subtotal": { "type": "number" },
        "shippingCost": { "type": "number" },
        "discountAmount": { "type": "number" },
        "total": { "type": "number" },
        "shippingAddress": { "type": "object" },
        "paymentStatus": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "WishlistItem": {
      "title": "WishlistItem",
      "description": "An item in the user's wishlist",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "imageUrl": { "type": "string" },
        "addedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "name", "price"]
    }
  },
  "firestore": {
    "users/{uid}": { "schema": "User", "description": "User profiles" },
    "users/{uid}/addresses/{aid}": { "schema": "Address", "description": "User addresses" },
    "categories/{id}": { "schema": "Category", "description": "Product categories" },
    "products/{id}": { "schema": "Product", "description": "Store products" },
    "orders/{id}": { "schema": "Order", "description": "Customer orders" },
    "coupons/{id}": { "schema": "object", "description": "Discount coupons" },
    "banners/{id}": { "schema": "object", "description": "Home banners" },
    "promoBanner/config": { "schema": "object", "description": "Global config" },
    "wishlists/{uid}/items/{productId}": { "schema": "WishlistItem", "description": "User wishlist items" }
  }
}
